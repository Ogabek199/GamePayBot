generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String         @id @default(uuid())
  telegramId    String         @unique
  username      String?
  firstName     String?
  photoUrl      String?
  role          String         @default("USER")
  language      String         @default("uz")
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  deposits      Deposit[]
  notifications Notification[]
  orders        Order[]
  transactions  Transaction[]
  wallets       Wallet?
}

model Wallet {
  id        String   @id @default(uuid())
  userId    String   @unique
  balance   Decimal  @default(0)
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id])
}

model PaymentCard {
  id         String    @id @default(uuid())
  cardHolder String
  cardNumber String
  bankName   String
  isActive   Boolean   @default(true)
  createdAt  DateTime  @default(now())
  deposits   Deposit[]
}

model Deposit {
  id        String      @id @default(uuid())
  userId    String
  cardId    String
  amount    Decimal
  status    String      @default("pending")
  adminNote String?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  user      User        @relation(fields: [userId], references: [id])
  card      PaymentCard @relation(fields: [cardId], references: [id])
}

model Transaction {
  id        String   @id @default(uuid())
  userId    String
  type      String
  amount    Decimal
  status    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model Game {
  id        String    @id @default(uuid())
  name      String
  slug      String    @unique
  logo      String?
  banner    String?
  status    String    @default("active")
  createdAt DateTime  @default(now())
  orders    Order[]
  packages  Package[]
}

model Package {
  id        String   @id @default(uuid())
  gameId    String
  title     String
  amount    Int
  price     Decimal
  image     String?
  status    String   @default("active")
  createdAt DateTime @default(now())
  orders    Order[]
  game      Game     @relation(fields: [gameId], references: [id])
}

model Order {
  id              String   @id @default(uuid())
  userId          String
  gameId          String
  packageId       String
  uid             String?
  region          String?
  price           Decimal
  currency        String
  status          String   @default("pending")
  paymentMethodId String?
  meta            String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  adminNote       String?
  user            User     @relation(fields: [userId], references: [id])
  game            Game     @relation(fields: [gameId], references: [id])
  package         Package  @relation(fields: [packageId], references: [id])
}

model PaymentMethod {
  id      String  @id @default(uuid())
  name    String
  type    String
  details String?
  active  Boolean @default(true)
}

model Banner {
  id        String   @id @default(uuid())
  image     String
  link      String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}

model PromoCode {
  id        String    @id @default(uuid())
  code      String    @unique
  amount    Decimal
  currency  String
  active    Boolean   @default(true)
  expiresAt DateTime?
  createdAt DateTime  @default(now())
}

model Admin {
  id        String     @id @default(uuid())
  username  String     @unique
  password  String
  role      String     @default("ADMIN")
  createdAt DateTime   @default(now())
  logs      AdminLog[]
}

model AdminLog {
  id        String   @id @default(uuid())
  adminId   String
  action    String
  target    String?
  createdAt DateTime @default(now())
  admin     Admin    @relation(fields: [adminId], references: [id])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model SupportTicket {
  id        String   @id @default(uuid())
  userId    String
  subject   String
  message   String
  status    String   @default("open")
  createdAt DateTime @default(now())
}
